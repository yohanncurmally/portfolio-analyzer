# Secrets: NEVER commit these
.env
.env.*
!.env.example

# Intermediate HTML for the README sample image (only the .png is committed)
docs/sample-dashboard.html

# Live portfolio snapshots & generated dashboards (private holdings)
outputs/*
!outputs/.gitkeep

# Your live tagging cache (holdings -> thesis buckets). tags.example.json is the
# shipped template; your real tags.json stays local.
tags.json

# Your per-holding deep-dive write-ups (thesis + scenarios + rationale). Contains your
# real views; writeups.example.json is the shipped template, writeups.json stays local.
writeups.json

# Your personal thesis, if you fill it in and don't want it public
# (uncomment the next line to keep your filled-in thesis out of git)
# docs/target_portfolio.md

# Python
.venv/
venv/
__pycache__/
*.pyc
*.pyo
.pytest_cache/

# OS / editor
.DS_Store
.idea/
.vscode/
*.swp
