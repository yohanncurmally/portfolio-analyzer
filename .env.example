# SnapTrade API credentials, from https://dashboard.snaptrade.com (Settings / API keys)
SNAPTRADE_CLIENT_ID=
SNAPTRADE_CONSUMER_KEY=

# Filled in after running scripts/register_snaptrade_user.py
SNAPTRADE_USER_ID=
SNAPTRADE_USER_SECRET=

# --- Interactive Brokers direct (only if using --source ibkr; all optional) ---
# Defaults work for IB Gateway live. Uncomment/adjust only if your port differs.
# Ports: IB Gateway live=4001 paper=4002 | TWS live=7496 paper=7497
# IBKR_HOST=127.0.0.1
# IBKR_PORT=4001
# IBKR_CLIENT_ID=17
